modules = ["nodejs-20"]
[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start bot"

[[workflows.workflow]]
name = "Start bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node bot.js"

[[ports]]
localPort = 3000
externalPort = 80
